  "item": [
    {
      "name": "GET Videos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"El código de estado es 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "\r",
              "pm.test(\"Todos los vídeos deben tener todas las propiedades\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    for(var i=0; i < jsonData.length; i++) {\r",
              "        pm.expect(jsonData[i]).to.have.property(\"id\");\r",
              "        pm.expect(jsonData[i]).to.have.property(\"name\")\r",
              "        pm.expect(jsonData[i]).to.have.property(\"description\")\r",
              "        pm.expect(jsonData[i]).to.have.property(\"user\")\r",
              "        pm.expect(jsonData[i]).to.have.property(\"releaseTime\")\r",
              "        pm.expect(jsonData[i]).to.have.property(\"comments\")\r",
              "        pm.expect(jsonData[i]).to.have.property(\"captions\")\r",
              "    }\r",
              "});\r",
              "\r",
              "var maxVideos = parseInt(pm.request.url.query.get(\"maxVideos\")) || 10;\r",
              "var maxPages = parseInt(pm.request.url.query.get(\"maxPages\")) || 2;\r",
              "const limite = maxPages * 100; // Limite DailyMotion = 100\r",
              "pm.test(`Validar límites: Solicitado ${maxVideos}, Máx Páginas ${maxPages} (Capacidad: ${limite} páginas como máximo)`, function () {\r",
              "     \r",
              "    const expectedMax = Math.min(maxVideos, limite);\r",
              "    var jsonData = pm.response.json();\r",
              "    var actualCount = jsonData.length;\r",
              "\r",
              "    pm.expect(actualCount).to.be.at.most(expectedMax, \r",
              "        `El servidor devolvió ${actualCount} vídeos, pero el límite combinado debería ser ${expectedMax}`);\r",
              "});\r",
              "\r",
              "pm.test(\"La estructura de user es correcta\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    jsonData.forEach(function(video) {\r",
              "        var user = video.user;\r",
              "        pm.expect(user.name).to.be.a('string').and.not.empty;\r",
              "        pm.expect(user.user_link).to.be.a('string').and.include('https://');\r",
              "        pm.expect(user.picture_link).to.be.a('string').and.include('https://');\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Los tipos de datos del vídeo son correcos\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    jsonData.forEach(function(video) {\r",
              "        pm.expect(video.id).to.be.a('string');\r",
              "        pm.expect(video.name).to.be.a('string').and.not.empty;\r",
              "        pm.expect(video.description).to.be.a('string');\r",
              "        pm.expect(video.releaseTime).to.be.a('string');\r",
              "        \r",
              "        // Validación de objetos anidados y arrays\r",
              "        pm.expect(video.user).to.be.an('object');\r",
              "        pm.expect(video.comments).to.be.an('array');\r",
              "        pm.expect(video.captions).to.be.an('array');\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
