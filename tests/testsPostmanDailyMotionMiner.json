    {
      "name": "GET Canales",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Estado es 200 OK\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"El cuerpo contiene un canal válido\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.id).to.eql(\"shortfilms\");\r",
              "    pm.expect(jsonData.videos).to.be.an('array');\r",
              "    pm.expect(jsonData.name).to.be.a('string');\r",
              "    pm.expect(jsonData.createdTime).to.exist;\r",
              "});\r",
              "\r",
              "var maxVideos = parseInt(pm.request.url.query.get(\"maxVideos\")) || 10;\r",
              "var maxPages = parseInt(pm.request.url.query.get(\"maxPages\")) || 2;\r",
              "const limite = maxPages * 100; // Limite DailyMotion = 100\r",
              "pm.test(`Validar límites: Solicitado ${maxVideos}, Máx Páginas ${maxPages} (Capacidad: ${limite} páginas como máximo)`, function () {\r",
              "     \r",
              "    const expectedMax = Math.min(maxVideos, limite);\r",
              "    var jsonData = pm.response.json();\r",
              "    var actualCount = jsonData.videos.length;\r",
              "\r",
              "    pm.expect(actualCount).to.be.at.most(expectedMax, \r",
              "        `El servidor devolvió ${actualCount} vídeos, pero el límite combinado debería ser ${expectedMax}`);\r",
              "});\r",
              "\r",
              "pm.test(\"Cada vídeo dentro del canal cumple el modelo VMVideo\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    \r",
              "    jsonData.videos.forEach(function(video, index) {\r",
              "        pm.expect(video.id).to.be.a('string').and.not.empty;\r",
              "        pm.expect(video.name).to.be.a('string').and.not.empty;\r",
              "        pm.expect(video.releaseTime).to.be.a('string');\r",
              "        pm.expect(video.comments).to.be.an('array');\r",
              "        pm.expect(video.captions).to.be.an('array');\r",
              "        pm.test(`El autor del vídeo ${video.id} es válido`, function () {\r",
              "            var user = video.user;\r",
              "            pm.expect(user).to.be.an('object');\r",
              "            pm.expect(user.name).to.be.a('string').and.not.empty;\r",
              "            pm.expect(user.user_link).to.be.a('string').and.include('https://');\r",
              "            pm.expect(user.picture_link).to.be.a('string').and.include('https://');\r",
              "        });\r",
              "    });\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
